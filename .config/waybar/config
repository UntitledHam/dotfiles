{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray","cpu", "memory", "temperature", "pulseaudio", "battery"],

    "modules": {
      "spacing": 10,
    },

      "hyprland/workspaces": {
        "disable-markup": false,
        "format": "{icon}",
        /*"format-icons": {
            "1": "1 <span font='Font Awesome 5 Free 11'> ´ëę</span>",
            "2": "2 <span font='Font Awesome 5 Free 11'> ´äá</span>",
            "3": "3 <span font='Font Awesome 5 Free 11'> ´äí</span>",
            "4": "4 <span font='Font Awesome 5 Free 11'> ´âá</span>",
            "5": "5 <span font='Font Awesome 5 Free 11'> ´ćś</span>",
            "6": "6 <span font='Font Awesome 5 Free 11'> ´ć╝</span>"
        }*/
    }, 
    "clock": {
        "format": "{:%Y-%m-%d | %H:%M}",
        "on-click": "gnome-calendar"
    },
    "hyprland/window": {
        "format": "ţş┐  >> {}",
        "separate-outputs": true
    },
    "temperature": {
	   	"thermal-zone": 0,
		"format": "{icon} {temperatureC}┬░C",
		"format-icons":["´őë"],
		"interval": 30
    },

    "battery": {
        "format": "<span font='Font Awesome 5 Free 11'>{icon} </span>  {capacity}%",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "format-time": "{H}h{M}m",
        "format-charging": "<span font='Font Awesome 5 Free'>´âž</span>  <span font='Font Awesome 5 Free 11'>{icon} </span>  {capacity}%",
        "format-full": "<span font='Font Awesome 5 Free'>´âž</span>  <span font='Font Awesome 5 Free 11'>{icon }</span>  Charged",
        "interval": 5,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": true, 
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-icons": {
                 "default": ["´ÇŽ", "´Çž", "´Çž", "´ÇĘ"]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol"
    },
    "backlight": {
        "format": "{icon}",
        "format-alt": "{percent}% {icon}",
        "format-alt-click": "click-right",
        "format-icons": ["´âź", "´Ö▓"],
        "on-scroll-down": "light -A 1",
        "on-scroll-up": "light -U 1"
       },
    "tray": {
        "icon-size": 22,
	"spacing": 2,
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 14,
        "icon-theme": "Papirus",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "cpu": {
        "interval": 5,
        "format": "´őŤ  {usage}%", // Icon: microchip
        "states": {
          "warning": 70,
          "critical": 90
        }
    },
    "memory": {
        "interval": 5,
        "format": "ˇ░ŹŤ  {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
 }  
